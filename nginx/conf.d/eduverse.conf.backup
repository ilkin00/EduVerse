# HTTP to HTTPS Redirect - Tüm domainler için
server {
    listen 80;
    server_name api.eduvers.site app.eduvers.site eduvers.site admin.eduvers.site;
    return 301 https://$server_name$request_uri;
}

# HTTPS - API Backend (api.eduvers.site)
server {
    listen 443 ssl;
    server_name api.eduvers.site;

    # SSL Sertifikaları
    ssl_certificate /etc/letsencrypt/live/api.eduvers.site/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.eduvers.site/privkey.pem;
    
    # SSL Konfigürasyonu
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    
    # Logging
    access_log /var/log/nginx/api-access.log;
    error_log /var/log/nginx/api-error.log;

    # Ana proxy
    location / {
        proxy_pass http://eduverse-backend:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Timeout ayarları
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }
    
    # WebSocket için özel konfigürasyon - DÜZELTİLDİ
    location /api/v1/ws/ {
        proxy_pass http://eduverse-backend:8000/api/v1/ws/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        
        # WebSocket timeout ayarları
        proxy_connect_timeout 7d;
        proxy_send_timeout 7d;
        proxy_read_timeout 7d;
    }
    
    # Static files (eğer varsa)
    location /static/ {
        alias /app/static/;
        expires 30d;
    }
    
    # Uploads (eğer varsa)
    location /uploads/ {
        alias /app/uploads/;
        expires 30d;
    }
}

# HTTPS - Mobile App (app.eduvers.site)
server {
    listen 443 ssl;
    server_name app.eduvers.site;

    # SSL Sertifikaları
    ssl_certificate /etc/letsencrypt/live/api.eduvers.site/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.eduvers.site/privkey.pem;
    
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    access_log /var/log/nginx/mobile-access.log;
    error_log /var/log/nginx/mobile-error.log;

    location / {
        proxy_pass http://eduverse-mobile:8081;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    
    # Expo için SockJS desteği
    location /sockjs-node/ {
        proxy_pass http://eduverse-mobile:8081/sockjs-node/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
    }
}

# HTTPS - Web App (eduvers.site)
server {
    listen 443 ssl;
    server_name eduvers.site;

    # SSL Sertifikaları
    ssl_certificate /etc/letsencrypt/live/api.eduvers.site/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.eduvers.site/privkey.pem;
    
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    access_log /var/log/nginx/web-access.log;
    error_log /var/log/nginx/web-error.log;

    # Web app build klasörü (eğer varsa)
    root /var/www/web-app/build;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }
    
    # API isteklerini backend'e yönlendir
    location /api/ {
        proxy_pass http://eduverse-backend:8000/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# HTTPS - Adminer (admin.eduvers.site)
server {
    listen 443 ssl;
    server_name admin.eduvers.site;

    # SSL Sertifikaları
    ssl_certificate /etc/letsencrypt/live/api.eduvers.site/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.eduvers.site/privkey.pem;
    
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    access_log /var/log/nginx/admin-access.log;
    error_log /var/log/nginx/admin-error.log;

    location / {
        proxy_pass http://eduverse-adminer:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
